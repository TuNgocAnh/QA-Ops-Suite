# QA Ops Suite - Environment Configuration
# ======================================
# Setup chỉ 1 bước:
#   python3 configs/setup-oauth.py
# → Browser mở → Đăng nhập Google → Xong!
#
# Script tự động tạo token và cập nhật file .env này.

# Google OAuth Refresh Token (tự động tạo sau khi chạy setup-oauth.py)
GOOGLE_OAUTH_REFRESH_TOKEN=

# Google Drive folder ID
# Nếu để trống, setup-oauth.py sẽ tự tạo folder mới trên Drive
# GOOGLE_DRIVE_FOLDER_ID=

# (Tùy chọn) Lark Drive folder ID - ưu tiên upload lên Lark nếu có
# Lấy từ URL: https://...larksuite.com/drive/folder/<FOLDER_ID>
# LARK_DRIVE_FOLDER_ID=

# Google OAuth Desktop client credentials (BẮT BUỘC nếu dùng Google Sheets upload)
# Tạo tại: https://console.cloud.google.com/apis/credentials
#   1. Tạo project mới (hoặc dùng project có sẵn)
#   2. Enable "Google Drive API" + "Google Sheets API"
#   3. Credentials => Create Credentials => OAuth client ID => Application type: Desktop app
#   4. Copy Client ID + Client Secret vào dưới
# GOOGLE_SHEETS_CLIENT_ID=
# GOOGLE_SHEETS_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=

# (Tùy chọn) Vai trò người dùng - dùng cho ước lượng Story Point
# Giá trị: junior / mid / senior / lead (mặc định: senior)
# USER_ROLE=senior

# Default Sprint & Version (dùng cho /log-bug khi user không cung cấp)
# DEFAULT_SPRINT=1-2026/4
# DEFAULT_VERSION=1.0.50

# Test account (tự động gắn vào mô tả bug khi /log-bug)
# TEST_ACCOUNT=0923267268 - 123456

# Check duplicate bug trước khi log (true/false). Mặc định: true
# CHECK_DUPLICATE_BUG=true

# Priority keywords cho /search-doc - boost ranking khi tài liệu chứa các từ khoá này
# Comma-separated, case + accent insensitive. Mặc định: "Sổ Bán Hàng,SoBanHang,SBH,Shinhan"
# LARK_WIKI_PRIORITY_KEYWORDS=Sổ Bán Hàng,SoBanHang,SBH,Shinhan

# =============================================================
# Lark Bitable - Board IDs (điền app_token và table_id từ URL)
# URL format: https://<domain>.larksuite.com/base/<BASE_ID>?table=<TABLE_ID>
# Hoặc dùng /update-board để tự động parse từ URL
# =============================================================

# Lark domain (used for building record URLs)
# LARK_DOMAIN=sobanhang.sg.larksuite.com

# Lark MCP credentials (lấy từ Lark Developer Console)
# Dùng cho .mcp.json — Claude Code sẽ substitute ${LARK_APP_ID} / ${LARK_APP_SECRET}
# LARK_APP_ID=
# LARK_APP_SECRET=

# Lark user access token (auto-managed bởi configs/setup-lark-oauth.py)
# Sau khi điền LARK_APP_ID / LARK_APP_SECRET => chạy:
#   python3 configs/setup-lark-oauth.py
# Browser mở => đăng nhập Lark => 3 biến dưới tự được ghi vào .env.
# Access token ~2h; refresh_token ~30 ngày (script tự refresh khi cần).
# LARK_USER_ACCESS_TOKEN=
# LARK_USER_REFRESH_TOKEN=
# LARK_USER_TOKEN_EXPIRY=

# --- Bug Board (bắt buộc cho /log-bug, /triage, /fix, /explain-bug) ---
# LARK_BUG_BASE_NAME=
# LARK_BUG_BASE_ID=
# LARK_BUG_TABLE_ID=
# LARK_BUG_VIEW_ID=
# LARK_BUG_WIKI_TOKEN=

# --- Task/Sprint Board (cho /sla, /release-check, /health) ---
# LARK_TASK_BASE_ID=
# LARK_TASK_TABLE_ID=
# LARK_TASK_VIEW_ID=
# LARK_TASK_WIKI_TOKEN=

# --- Test Execution Board (tùy chọn - cho /release-check, /health) ---
# LARK_TEST_BASE_ID=
# LARK_TEST_TABLE_ID=
# LARK_TEST_VIEW_ID=
# LARK_TEST_WIKI_TOKEN=

# =============================================================
# Lark Bitable - Field Mapping (tùy chọn, auto-detect nếu bỏ trống)
# Đặt tên field trong Bitable nếu khác mặc định
# =============================================================

# Bug board field names (mặc định)
# LARK_BUG_FIELD_TITLE=Title
# LARK_BUG_FIELD_DESCRIPTION=Description
# LARK_BUG_FIELD_STATUS=Status
# LARK_BUG_FIELD_PRIORITY=Priority
# LARK_BUG_FIELD_ASSIGNEE=Assignee
# LARK_BUG_FIELD_ATTACHMENT=Attachment
# LARK_BUG_FIELD_REPORTER=Reporter
# LARK_BUG_FIELD_CREATED=Created
